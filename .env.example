# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# LinkedIn credentials (optional - for authenticated scraping)
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password-here

# Internshala credentials (optional - for authenticated scraping)
INTERNSHALA_EMAIL=your-email@example.com
INTERNSHALA_PASSWORD=your-password-here

# Flask secret key
FLASK_SECRET_KEY=change-this-to-a-random-string

# Model Configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# Scraper Configuration
SCRAPE_DELAY_SECONDS=3
MAX_JOBS_PER_SCRAPE=50
HEADLESS_BROWSER=true
